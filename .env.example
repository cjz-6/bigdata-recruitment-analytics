# =============================================================================
# 项目环境变量配置（模板）
# 复制此文件为 .env 并填入真实值
# =============================================================================

# ─── MySQL ───
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=job_analysis
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# ─── Flask 后端 ───
FLASK_ENV=production
FLASK_APP=app.main:app

# ─── Dify ───
DIFY_SECRET_KEY=your_dify_secret_key
DIFY_CONSOLE_WEB_URL=http://your_host:8080
DIFY_CONSOLE_API_URL=http://your_host:8080
DIFY_SERVICE_API_URL=http://your_host:8080
DIFY_APP_WEB_URL=http://your_host:8080
DIFY_APP_API_URL=http://your_host:8080
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=your_dify_db_password
DIFY_DB_NAME=dify
DIFY_REDIS_PASSWORD=your_dify_redis_password

# ─── Dify API Integration ───
DIFY_API_KEY=your_dify_api_key
DIFY_API_URL=http://dify-proxy:80
DIFY_API_TIMEOUT=60
